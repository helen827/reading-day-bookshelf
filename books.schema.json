{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/books.enriched.schema.json",
  "title": "EnrichedBookList",
  "description": "Front-end ready book recommendation payload enriched with cover URLs and ISBN data.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "generated_at",
    "source_document",
    "books"
  ],
  "properties": {
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "source_document": {
      "type": "string",
      "description": "Original Word document path or filename."
    },
    "books": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/book"
      }
    },
    "stats": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total",
        "with_isbn",
        "with_cover_url"
      ],
      "properties": {
        "total": {
          "type": "integer",
          "minimum": 0
        },
        "with_isbn": {
          "type": "integer",
          "minimum": 0
        },
        "with_cover_url": {
          "type": "integer",
          "minimum": 0
        }
      }
    }
  },
  "$defs": {
    "book": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "recommender",
        "recommendation",
        "quote",
        "isbn",
        "cover_url",
        "enrichment"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^book-\\d{3}$"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "recommender": {
          "type": "string",
          "minLength": 1
        },
        "author": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "recommendation": {
          "type": "string",
          "minLength": 1
        },
        "quote": {
          "type": "string",
          "minLength": 1
        },
        "isbn": {
          "description": "Best available ISBN. Prefer ISBN-13 when present.",
          "type": [
            "string",
            "null"
          ],
          "pattern": "^(97[89]\\d{10}|\\d{9}[\\dXx])$"
        },
        "isbn10": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^\\d{9}[\\dXx]$"
        },
        "isbn13": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^97[89]\\d{10}$"
        },
        "cover_url": {
          "type": [
            "string",
            "null"
          ],
          "format": "uri"
        },
        "cover_thumbnail_url": {
          "type": [
            "string",
            "null"
          ],
          "format": "uri"
        },
        "enrichment": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "source",
            "matched_title",
            "confidence"
          ],
          "properties": {
            "source": {
              "type": [
                "string",
                "null"
              ],
              "enum": [
                "openlibrary",
                "google_books",
                "douban",
                "megbook",
                "publisher",
                null
              ]
            },
            "matched_title": {
              "type": [
                "string",
                "null"
              ]
            },
            "confidence": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            }
          }
        }
      }
    }
  }
}
